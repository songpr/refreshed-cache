{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "lib": ["es2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "noEmit": true,
    "types": [
      "node"
    ],
    "allowJs": true
  },
  "include": [
    "index.d.ts",
    "index.js",
    "test/**/*.ts"
  ],
  "exclude": [
    "**/*.test-d.ts"
  ]
}
